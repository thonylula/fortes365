# Copie para .env.local e preencha com os valores do seu projeto Supabase.
# Encontre em: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...  # "anon public" key

# Supabase Service Role Key (NUNCA exponha no frontend — só para webhooks server-side)
# Encontre em: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Kimi 2.5 (Coach IA) — grátis
# Crie conta em platform.moonshot.ai → API Keys → Create
KIMI_API_KEY=sk-...

# PostHog Analytics (opcional — funciona sem, só não tracka)
# Crie conta em posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# Mercado Pago — Credenciais de teste
# Encontre em: mercadopago.com.br/developers → Sua aplicação → Credenciais de teste
MP_ACCESS_TOKEN=APP_USR-...

# Resend — Emails transacionais (bem-vindo, pagamento confirmado, conta excluída)
# Crie conta grátis em resend.com → API Keys → Create API Key (3k emails/mês grátis)
# Sem essa chave o app funciona normal, só não envia emails (log de aviso no servidor)
RESEND_API_KEY=re_...

# Remetente dos emails (opcional). Default usa o domínio de teste do Resend.
# Quando comprar um domínio próprio (ex. registro.br, R$40/ano) e verificá-lo
# no dashboard do Resend, troque aqui para "FORTE 365 <contato@seudominio.com.br>"
# EMAIL_FROM="FORTE 365 <onboarding@resend.dev>"

# Google Fit OAuth — sincronização de passos/FC/calorias no dashboard
# Criar em console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Habilitar "Fitness API" em APIs & Services → Library
# Adicionar redirect URIs: http://localhost:3100/api/google-fit/callback + https://fortes365.vercel.app/api/google-fit/callback
# Em "OAuth consent screen" (External): escopos fitness.activity.read + fitness.heart_rate.read. Adicionar emails em "Test users" enquanto app não passa por verification.
GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_OAUTH_REDIRECT_URI=https://fortes365.vercel.app/api/google-fit/callback

# Secret para assinar o state do OAuth (previne CSRF). Gere com: openssl rand -hex 32
OAUTH_STATE_SECRET=...

# Emails com acesso admin (rotas /api/admin/*, como precache de videos).
# Lista separada por virgula, case-insensitive.
ADMIN_EMAILS=thonylula.oliveira@gmail.com
